{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "foxdock-desktop",
  "version": "0.1.0",
  "identifier": "com.foxapplication.foxdock",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FoxDock Desktop",
        "width": 480,
        "height": 720,
        "minWidth": 480,
        "minHeight": 600,
        "maxWidth": 480,
        "resizable": true,
        "decorations": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
